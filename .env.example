# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# ── Model calls ──────────────────────────────────────────────────────────────
BRAIN_MODEL_PROVIDER=bedrock              # bedrock | openai
# Bedrock (default): set a model/inference-profile your AWS account can use.
BRAIN_BEDROCK_MODEL=us.anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_REGION_NAME=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_PROFILE=
# OpenAI (only if BRAIN_MODEL_PROVIDER=openai):
# OPENAI_API_KEY=
# BRAIN_AGENT_MODEL=gpt-5-mini

# ── Exa (web search) ─────────────────────────────────────────────────────────
EXA_API_KEY=

# ── Slack ────────────────────────────────────────────────────────────────────
# Bot User OAuth Token (scopes: chat:write, chat:write.public, channels:read)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# App-Level Token (xapp-...) for Socket Mode inbound, once that's built:
# SLACK_APP_TOKEN=
